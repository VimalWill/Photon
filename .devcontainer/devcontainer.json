{
  "name": "cuda-12.2-dev",
  "image": "nvidia/cuda:12.2.2-devel-ubuntu22.04",
  "workspaceFolder": "/workspace",
  "runArgs": ["--rm"],
  "mounts": [
    "source=${localWorkspaceFolder},target=/workspace,type=bind"
  ],
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-vscode.cpptools",
        "ms-python.python"
      ]
    }
  },
  "postCreateCommand": "apt update && apt install -y git cmake ninja-build python3 python3-pip"
}a